    def read_serial(self):
        """Read data from serial port and process it"""
        last_plot_update = time.time()
        activity_data = deque(maxlen=100)  # For plotting activity
        feature_data = deque(maxlen=100)   # For plotting features
        
        while self.serial_port is not None:
            try:
                if self.serial_port.in_waiting:
                    data = self.serial_port.readline().decode().strip()
                    if data:
                        try:
                            value = float(data)
                            
                            # Performance optimization
                            self.sample_counter += 1
                            if self.sample_counter % self.process_every != 0:
                                continue
                            
                            current_time = time.time()
                            
                            # Update data buffers
                            self.data_buffer.append(value)
                            self.analysis_buffer.append(value)
                            
                            # Process if we have enough data
                            if len(self.analysis_buffer) >= 2:
                                # Calculate slope
                                data_for_processing = list(self.analysis_buffer)
                                slope = self.calculate_slope(data_for_processing)
                                self.slope_buffer.append(slope)
                                
                                # Update displays (throttled)
                                if self.sample_counter % 5 == 0:
                                    self.value_label.config(text=f"Signal: {value:.1f}")
                                    self.slope_label.config(text=f"Slope: {slope:.2f}")
                                
                                # Update state based on measurements
                                self.update_state(value, slope)
                                
                                # Add activity data for plotting
                                activity_data.append(self.activity_ratio)
                                
                                # Add feature data for plotting (use first feature as example)
                                if len(self.feature_buffer) > 0:
                                    feature_data.append(self.feature_buffer[-1][0])  # Mean signal
                                
                                # Make prediction if active
                                if self.is_predicting and self.sample_counter % 5 == 0:
                                    prediction, confidence = self.predict_with_neural_network()
                                    if prediction:
                                        # Color coding based on prediction
                                        color = 'red' if prediction == "CLOSE" else 'green'
                                        
                                        # Add indicator for low confidence (threshold rule applied)
                                        if confidence < 0.6:
                                            prediction_text = f"Prediction: {prediction} (Low Conf)"
                                            color = 'orange'  # Different color for low confidence
                                        else:
                                            prediction_text = f"Prediction: {prediction}"
                                        
                                        self.prediction_label.config(
                                            text=prediction_text,
                                            foreground=color
                                        )
                                        self.confidence_label.config(text=f"Confidence: {confidence:.3f}")
                                        
                                        # Send feedback to Arduino
                                        self.send_feedback_to_arduino(prediction)
                            
                            # Update plots at the specified interval
                            if (current_time - last_plot_update) * 1000 > self.update_interval:
                                # Update signal plot
                                self.line1.set_data(range(len(self.data_buffer)), list(self.data_buffer))
                                self.ax1.relim()
                                self.ax1.autoscale_view()
                                
                                # Update activity plot
                                if len(activity_data) > 0:
                                    self.line2.set_data(range(len(activity_data)), list(activity_data))
                                    self.ax2.relim()
                                    self.ax2.set_ylim(0, 1.1)  # Fixed y-axis for activity
                                
                                # Update feature plot
                                if len(feature_data) > 0:
                                    self.line3.set_data(range(len(feature_data)), list(feature_data))
                                    self.ax3.relim()
                                    self.ax3.autoscale_view()
                                
                                # Draw plots
                                self.fig.canvas.draw_idle()
                                last_plot_update = current_time
                        
                        except ValueError:
                            # Skip invalid data
                            pass
                            
            except Exception as e:
                print(f"Serial error: {str(e)}")
                if self.serial_port is None:
                    break
    
