    def toggle_connection(self):
        """Connect or disconnect from serial port"""
        if self.serial_port is None:
            try:
                port = self.port_entry.get()
                self.serial_port = serial.Serial(port, 9600, timeout=1)
                self.connect_btn.config(text="Disconnect")
                self.status_bar.config(text=f"Connected to {port} | Neural Network Mode")
                
                # Update feedback status if enabled
                if self.feedback_enabled:
                    self.feedback_status_label.config(text="Feedback: Enabled", foreground="green")
                
                # Start reading thread
                threading.Thread(target=self.read_serial, daemon=True).start()
                
            except Exception as e:
                messagebox.showerror("Connection Error", str(e))
        else:
            # Disconnect
            try:
                self.serial_port.close()
            except:
                pass
                
            self.serial_port = None
            self.connect_btn.config(text="Connect")
            self.status_bar.config(text="Not Connected | Neural Network Mode")
            
            # Update feedback status
            if self.feedback_enabled:
                self.feedback_status_label.config(text="Feedback: Enabled (No Connection)", foreground="orange")
    
    def toggle_recording(self):
        """Start or stop recording gesture data"""
        if not self.is_recording:
            # Check if connected
            if self.serial_port is None:
                messagebox.showerror("Error", "Please connect to device first")
                return
                
            # Start recording
            self.is_recording = True
            self.current_gesture = self.gesture_var.get()
            self.record_btn.config(text="Stop Recording")
            self.status_bar.config(text=f"Recording {self.current_gesture} gesture...")
            
            # Reset for new recording
            self.state_history.clear()
            self.window_activity.clear()
            
        else:
            # Stop recording
            self.is_recording = False
            self.record_btn.config(text="Start Recording")
            
            if self.serial_port:
                self.status_bar.config(text=f"Connected to {self.port_entry.get()} | Neural Network Mode")
            else:
                self.status_bar.config(text="Not Connected | Neural Network Mode")
            
            # Update analysis with new data
            self.update_analysis_display()
            
            self.current_gesture = None
    
